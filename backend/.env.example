# TWISTED Glass Engine Configuration
# Copy to .env and fill in your keys

# Required: Google Gemini API (Tier 1 by default)
GEMINI_API_KEY=your_gemini_api_key_here

# Required: GitHub Token for build agents (get from finasteos org settings)
# Scope needed: admin:enterprise, admin:org, repo, user, workflow
GITHUB_TOKEN=your_github_token_here

# Optional: Rate limit percentage (0.1 = 10%, 0.5 = 50%)
RATE_LIMIT_PERCENTAGE=0.1

# Optional: Web Search APIs
SERPAPI_KEY=your_serpapi_key_here
TAVILY_API_KEY=your_tavily_key_here

# Optional: Security
# ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

# Development
DEBUG=true
